APP_ID=tilechat
MONGODB_URI=mongodb://localhost:27017/chatdb
RABBITMQ_URI=amqp://ignored:RABBIT_JWT_TOKEN@localhost:5672?heartbeat=60
WEBHOOK_ENABLED=true
WEBHOOK_ENDPOINTS=http://localhost:8002/postdata, http://localhost:8002/postdata2
WEBHOOK_EVENTS=message-sent,conversation-archived
LOG_LEVEL=DEBUG
PREFETCH_MESSAGES=50
NODE_TLS_REJECT_UNAUTHORIZED="0"
PRESENCE_ENABLED=true
ANALYTICS_ENABLED=false
ANALYTICS_EXCHANGE=tiledesk.analytics
ANALYTICS_RABBITMQ_URI=amqp://localhost:5673
TEST_APPID="tilechat"
TEST_CLIENT_API_LOG=false
TEST_HTTP_SERVER_LOG_LEVEL=error
TEST_OBSERVER_LOG_LEVEL=error
TEST_LOCAL_STACK=true
TEST_MQTT_ENDPOINT=ws://localhost:15675/ws
TEST_API_ENDPOINT=http://localhost:8004/api

# Performance testing — cache ON vs OFF comparison (perfomance/run_cache_comparison.sh)
PERFORMANCE_TEST_TILEDESK_PROJECT_ID=your_project_id
PERFORMANCE_TEST_MQTT_ENDPOINT=ws://your-k8s-host/mqws/ws
PERFORMANCE_TEST_API_ENDPOINT=http://your-k8s-host/api
PERFORMANCE_TEST_CHAT_API_ENDPOINT=http://your-k8s-host/chatapi/api
PERFORMANCE_TEST_LABEL=cache_on
PERFORMANCE_TEST_NUM_MESSAGES=10
PERFORMANCE_TEST_REPLY_TIMEOUT_MS=120000
PERFORMANCE_TEST_SKIP_FIRST=true